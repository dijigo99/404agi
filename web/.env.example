# ────────────────────────────────────────────────────────────────────────
# 404AGI / web — environment variables
# Copy to `.env.local` for local dev. Set the same in Vercel for prod.
# ────────────────────────────────────────────────────────────────────────

# Google Gemini API key. Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Token contract address on Solana mainnet.
# Leave EMPTY before launch — UI will show "AWAITING DEPLOYMENT".
# Update this immediately after pump.fun deploy and redeploy.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Public Solana RPC endpoint. Default is the Solana public node (rate-limited).
# For prod use Helius free tier: https://helius.dev
NEXT_PUBLIC_HELIUS_RPC=https://api.mainnet-beta.solana.com

# Public wallet addresses (shown in the Tokenomics section).
# Use Solscan-verifiable mainnet addresses.
NEXT_PUBLIC_DEPLOYER_WALLET=
NEXT_PUBLIC_MARKETING_WALLET=
NEXT_PUBLIC_AGENT_WALLET=

# Upstash Redis (chat memory + per-wallet rate limit).
# Add an Upstash Redis integration in Vercel Marketplace; both vars get auto-set.
# https://vercel.com/marketplace?category=storage&search=redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
