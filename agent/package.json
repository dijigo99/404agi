{
  "name": "coin-agent",
  "version": "0.1.0",
  "private": true,
  "description": "404AGI character engine — autonomous tweet generator + response endpoint",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "tweet:gen": "tsx scripts/generate-tweet.ts",
    "test:prompts": "tsx scripts/test-prompts.ts",
    "wallet:tweet": "tsx scripts/wallet-event.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
