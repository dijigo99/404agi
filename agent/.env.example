# 404AGI Agent — environment variables

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Models (defaults are sane — only override if you know what you're doing)
GEMINI_MODEL_TWEET=gemini-2.0-flash
GEMINI_MODEL_CHAT=gemini-2.5-flash

# HTTP server
PORT=8787
HOST=0.0.0.0

# Optional shared secret for /respond endpoint (web app must send X-Agent-Token).
# Leave blank in dev. Set in production.
AGENT_SHARED_SECRET=

# Kill switch: when set to "1", the agent will refuse to generate any output.
# Manual override for the main brain to halt the character if it goes off-rails.
AGENT_KILL_SWITCH=0

# Rate limits (per hour)
RATE_LIMIT_TWEET_PER_HOUR=4
RATE_LIMIT_RESPONSE_PER_HOUR=10

# Memory store path (JSON file). Defaults to ./.memory/store.json
MEMORY_STORE_PATH=

# Logging
LOG_LEVEL=info
TWEET_LOG_PATH=./.logs/tweets.jsonl
