# Bot — @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=

# Token contract address (launch sonrası set edilir, boşsa /buy /price disabled fallback)
CONTRACT_ADDRESS=

# Sosyal/varlık linkleri
SITE_URL=https://404agi.fun
X_URL=https://x.com/404agi_coin
GITHUB_URL=https://github.com/dijigo99/404agi

# Telegram entity ID'leri (negatif sayılar — bot eklendikten sonra log'tan al)
MAIN_GROUP_CHAT_ID=
TR_GROUP_CHAT_ID=
NEWS_CHANNEL_CHAT_ID=

# Admin user ID'leri (virgülle ayrılır) — /announce yetkisi için
ADMIN_USER_IDS=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Buy alert
BUY_ALERT_MIN_USD=50
BUY_ALERT_POLL_MS=60000

# Rate limit (per user, per hour)
ASK_RATE_LIMIT_PER_HOUR=5

# Announce API auth
ANNOUNCE_API_KEY=

# Server
PORT=3000
