# ===========================================================================
# 404AGI Telegram Bot — Vercel webhook mode
# ===========================================================================

# --- Bot ---
# @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=
# Bot username (@'siz, örn: the404agi_bot) — mention parser için
BOT_USERNAME=

# --- Webhook security (zorunlu prod'da) ---
# Telegram'ın setWebhook secret_token'ı; her POST'ta doğrulanır.
# Üret: openssl rand -hex 32
WEBHOOK_SECRET=

# Vercel Cron Bearer token (Vercel otomatik gönderir, env'de set edersen doğrulanır)
# Üret: openssl rand -hex 32
CRON_SECRET=

# --- Cross-service announce HTTP API ---
# Bearer token, web app /announce çağrısı için
ANNOUNCE_API_KEY=

# --- KV (Upstash Redis) — rate limit + dup detection + buy alert state ---
# Vercel'de KV (Marketplace > Storage > Upstash Redis) bağladığında otomatik gelir
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Token & sosyal linkler ---
CONTRACT_ADDRESS=
SITE_URL=https://404agi.fun
X_URL=https://x.com/404agi_coin
GITHUB_URL=https://github.com/dijigo99/404agi

# --- Telegram entity ID'leri (negatif sayılar — bot eklendikten sonra log'tan al) ---
MAIN_GROUP_CHAT_ID=
TR_GROUP_CHAT_ID=
NEWS_CHANNEL_CHAT_ID=

# --- Admin user ID'leri (virgülle ayrılır) — /announce yetkisi için ---
ADMIN_USER_IDS=

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Buy alert ---
BUY_ALERT_MIN_USD=50

# --- Rate limit (per user, per hour) ---
ASK_RATE_LIMIT_PER_HOUR=5
