{
  "name": "404agi-telegram-bot",
  "version": "0.2.0",
  "description": "404AGI ($404) Telegram bot — Vercel webhook mode (commands, buy alert, AI ask, moderation)",
  "private": true,
  "scripts": {
    "dev": "vercel dev",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "webhook:set": "tsx scripts/set-webhook.ts",
    "webhook:delete": "tsx scripts/delete-webhook.ts",
    "commands:set": "tsx scripts/set-commands.ts",
    "smoke": "tsx scripts/smoke-test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@upstash/redis": "^1.34.3",
    "@vercel/node": "^3.2.24",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
